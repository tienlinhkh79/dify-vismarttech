# Copy nội dung vào `docker/.env` (hoặc chạy: Get-Content env.billing.activate.example >> .env trong thư mục docker)
# Rồi: docker compose up -d api worker worker_beat billing_saas
BILLING_ENABLED=true
BILLING_API_URL=http://billing_saas:8000
BILLING_API_SECRET_KEY=dev-billing-secret-change-me

# --- 9Pay (cổng sand-payment.9pay.vn — thẻ, ATM, ví, QR tuỳ sản phẩm merchant) ---
# Tài liệu: https://developers.9pay.vn/ — Redirect thẻ QT: https://developers.9pay.vn/thanh-toan-the-quoc-te/redirect
# Mẫu ký REST (inquire/refund): https://gitlab.com/9pay-sample/sample-php (MessageBuilder + HMACSignature)
# Bật khi đã có Merchant Key + Secret Key + Key Checksum (chỉ trong .env, không commit).
# NINEPAY_ENABLED=true
# NINEPAY_ENDPOINT=https://sand-payment.9pay.vn
# NINEPAY_MERCHANT_KEY=
# NINEPAY_SECRET_KEY=
# NINEPAY_CHECKSUM_KEY=
# URL người dùng quay lại sau thanh toán (Next.js /billing/9pay-return, HTTPS công khai).
# NINEPAY_RETURN_URL_BASE=https://your-console.example.com/billing/9pay-return
# JSON số tiền VND (tối thiểu 10_000), key dạng plan_interval:
# NINEPAY_PLAN_AMOUNTS_VND={"professional_month":1475000,"professional_year":15900000,"team_month":3975000,"team_year":42900000}
# Để khách chọn nhiều phương thức trên cổng 9Pay: để trống NINEPAY_METHOD. Ép thẻ quốc tế: NINEPAY_METHOD=CREDIT_CARD
# NINEPAY_METHOD=
# NINEPAY_TRANSACTION_TYPE=
# NINEPAY_LANG=vi
# NINEPAY_CURRENCY=VND
# NINEPAY_BANK_CODE=
# NINEPAY_PROFILE_ID=
# NINEPAY_CARD_ORIGIN_ALLOW=
# NINEPAY_CARD_BRAND_ALLOW=
# NINEPAY_BIN_ALLOW=
# NINEPAY_CARD_TYPE_ALLOW=
# NINEPAY_CAMPAIGN_ID=
# IPN thanh toán: đăng ký trên merchant 9Pay URL công khai (nginx trong repo đã proxy):
#   https://<host-công-khai>/webhooks/9pay/ipn  → billing_saas:8000/webhooks/9pay/ipn
# Nếu không dùng nginx fork: expose billing_saas hoặc tự cấu hình reverse proxy tương đương.
# Polling inquire khi thiếu IPN (doc ~20 phút): chu kỳ (giây) và tuổi pending tối thiểu trước khi hỏi 9Pay.
# NINEPAY_INQUIRE_POLL_SECONDS=900
# NINEPAY_INQUIRE_AFTER_SECONDS=1200
# API nội bộ (header Billing-Api-Secret-Key): POST /internal/ninepay/sync-stale-pending
# GET /internal/ninepay/inquire/{invoice_no} | POST /internal/ninepay/refund | GET /internal/ninepay/refund-inquire/{request_id}

# --- Stub khi chưa bật NINEPAY (tránh example.com) ---
# `run-cloudflare-and-sync.ps1` / `sync-cloudflare-url.ps1` tự gán theo tunnel. Có thể chỉnh tay:
# BILLING_CHECKOUT_BASE_URL=https://your-host/billing/checkout
# BILLING_INVOICES_URL=https://your-host/account
